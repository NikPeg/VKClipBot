# Токен группы (бота)
BOT_TOKEN=

# Токен владельца
USER_TOKEN=

# Айди группы
GROUP_ID=

# Айди бесед с ботом (через запятую, например: 1,2,3)
CONVERSATION_IDS=

# Название и описание клипа
CLIP_NAME=
CLIP_DESCRIPTION=

# Директория для сохранения клипов
CLIPS_DIR=clips

# Расписание: время начала и конца цикла загрузки (час и минута)
START_HOUR=21
START_MINUTE=0
END_HOUR=23
END_MINUTE=59

# Интервал постинга клипов в часах
POSTING_INTERVAL=1

# Интервал проверки и удаления старых клипов в часах
CLEANUP_INTERVAL_HOURS=24

# Дата/время последнего поста по умолчанию (если state.json ещё не создан)
LAST_TIME_POST_DEFAULT=2025-06-16 21:25:30

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Загрузка видео через yt-dlp
USE_YTDLP=true
YTDLP_PATH=yt-dlp
